# Environment variables for Dola AI
# Completely FREE setup - No payments needed!

# Option 1: FREE OpenRouter API (Recommended)
# Get free key at https://openrouter.ai (sign up with GitHub)
# Includes free credits for testing!
OPENROUTER_API_KEY=your-free-openrouter-key-here

# Option 2: FREE Hugging Face API
# Get free key at https://huggingface.co/settings/tokens
# HF_API_KEY=your-free-huggingface-key-here

# Option 3: FREE Ollama (Local AI - Runs on your machine)
# Download from https://ollama.ai
# OLLAMA_MODEL=mistral

# Node environment
NODE_ENV=development
PORT=3000

# Choose which API to use: 'openrouter', 'huggingface', or 'ollama'
AI_PROVIDER=openrouter
